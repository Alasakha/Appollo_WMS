<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mgkj.mapper.PurchaseSummaryMapper">

    <select id="bacodeisExist" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM purchase_summary WHERE create_by = #{createBy}	AND barcode = #{barcode}
    </select>
</mapper>
