<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mgkj.mapper.BadTableMapper">


    <insert id="add" keyProperty="id" useGeneratedKeys="true">
        insert into badTable(badNumber, badName, remark)
        values (#{badNumber},#{badName},#{remark})
    </insert>

    <update id="modify">
        update badTable
        <trim prefix="set" suffixOverrides=",">
            <if test="remark != null and remark != '' "> remark = #{remark},</if>
            <if test="badName != null and badName != '' "> badName = #{badName},</if>
        </trim>
        where id = #{id}
    </update>

    <select id="find" resultType="com.mgkj.entity.BadTable">
        select * from badTable
        where 1=1
        <if test="id != null" > and id = #{id}</if>
        <if test=" badNumber != null and  badNumber != '' " > and  badNumber = #{ badNumber}</if>

    </select>
</mapper>
